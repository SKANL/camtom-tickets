{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@camtom/shared": ["../shared/src"]
    }
  },
  "include": ["src"],
  "exclude": ["src/__tests__"],
  "references": [{ "path": "../shared" }]
}
