{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@camtom/shared": ["./shared/src"]
    }
  },
  "include": ["api/**/*.ts"],
  "exclude": ["node_modules", "**/__tests__/**", "**/dist/**"]
}
